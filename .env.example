# Copy to .env.local and replace placeholders with your Supabase project values.
# Next.js load order: .env → .env.local (local wins) → .env.development → .env.development.local

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only (API route inserts). Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
